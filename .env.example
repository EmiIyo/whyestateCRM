# Supabase ---------------------------------------------------------------
# Project URL and publishable (anon) key. Both safe to ship in the bundle —
# RLS policies are what guard the data.
VITE_SUPABASE_URL=https://qlfuyhdhimjbdllgiype.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_publishable_key

# fal.ai photo proxy (Edge Function) -------------------------------------
# Optional: only required if the Photo Studio module is in use. The actual
# FAL_KEY lives as a Supabase secret on the edge function, never in the
# client bundle.
VITE_FAL_PROXY_URL=https://qlfuyhdhimjbdllgiype.supabase.co/functions/v1/fal-proxy

# Feature flags ----------------------------------------------------------
# Lovable.dev route-messaging integration (dev-only).
VITE_ENABLE_ROUTE_MESSAGING=false
